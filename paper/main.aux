\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Average FAC, RSC, and ARCG across all 30 problems for the five evaluated models. All models exhibit a strongly negative ARCG, indicating that reasoning chains are significantly more stable than final answers across semantic paraphrases.}}{4}{table.1}\protected@file@percent }
\newlabel{tab:main_results}{{1}{4}{Average FAC, RSC, and ARCG across all 30 problems for the five evaluated models. All models exhibit a strongly negative ARCG, indicating that reasoning chains are significantly more stable than final answers across semantic paraphrases}{table.1}{}}
